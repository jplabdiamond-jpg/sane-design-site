---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import CTABanner from '../components/CTABanner.astro';
import { getCollection } from 'astro:content';

const works = (await getCollection('works', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

const blogs = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <!-- ── Hero ── -->
  <section style="min-height: calc(90vh - 64px); display:flex; flex-direction:column; justify-content:flex-end; padding-bottom:80px; position:relative; overflow:hidden;">
    <!-- Background: Cyber mesh SVG + CSS animation -->
    <div class="hero-bg" aria-hidden="true">
      <svg class="hero-svg" viewBox="0 0 1440 800" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <!-- Grid lines vertical -->
        <g stroke="rgba(0,0,40,0.10)" stroke-width="0.8">
          <line x1="80"  y1="0" x2="80"  y2="800"/>
          <line x1="160" y1="0" x2="160" y2="800"/>
          <line x1="240" y1="0" x2="240" y2="800"/>
          <line x1="320" y1="0" x2="320" y2="800"/>
          <line x1="400" y1="0" x2="400" y2="800"/>
          <line x1="480" y1="0" x2="480" y2="800"/>
          <line x1="560" y1="0" x2="560" y2="800"/>
          <line x1="640" y1="0" x2="640" y2="800"/>
          <line x1="720" y1="0" x2="720" y2="800"/>
          <line x1="800" y1="0" x2="800" y2="800"/>
          <line x1="880" y1="0" x2="880" y2="800"/>
          <line x1="960" y1="0" x2="960" y2="800"/>
          <line x1="1040" y1="0" x2="1040" y2="800"/>
          <line x1="1120" y1="0" x2="1120" y2="800"/>
          <line x1="1200" y1="0" x2="1200" y2="800"/>
          <line x1="1280" y1="0" x2="1280" y2="800"/>
          <line x1="1360" y1="0" x2="1360" y2="800"/>
        </g>
        <!-- Grid lines horizontal -->
        <g stroke="rgba(0,0,40,0.10)" stroke-width="0.8">
          <line x1="0" y1="80"  x2="1440" y2="80"/>
          <line x1="0" y1="160" x2="1440" y2="160"/>
          <line x1="0" y1="240" x2="1440" y2="240"/>
          <line x1="0" y1="320" x2="1440" y2="320"/>
          <line x1="0" y1="400" x2="1440" y2="400"/>
          <line x1="0" y1="480" x2="1440" y2="480"/>
          <line x1="0" y1="560" x2="1440" y2="560"/>
          <line x1="0" y1="640" x2="1440" y2="640"/>
          <line x1="0" y1="720" x2="1440" y2="720"/>
        </g>
        <!-- Floating nodes -->
        <g fill="rgba(40,40,100,0.45)">
          <circle class="node n1" cx="120"  cy="180" r="2.5"/>
          <circle class="node n2" cx="380"  cy="320" r="2"/>
          <circle class="node n3" cx="640"  cy="140" r="3"/>
          <circle class="node n4" cx="820"  cy="420" r="2"/>
          <circle class="node n5" cx="1050" cy="260" r="2.5"/>
          <circle class="node n6" cx="1280" cy="380" r="2"/>
          <circle class="node n7" cx="200"  cy="520" r="2"/>
          <circle class="node n8" cx="480"  cy="600" r="2.5"/>
          <circle class="node n9" cx="760"  cy="560" r="2"/>
          <circle class="node n10" cx="980" cy="680" r="3"/>
          <circle class="node n11" cx="1150" cy="500" r="2"/>
          <circle class="node n12" cx="320"  cy="700" r="2.5"/>
        </g>
        <!-- Connection lines between nodes -->
        <g stroke="rgba(40,40,100,0.18)" stroke-width="0.8" fill="none">
          <line class="edge e1" x1="120" y1="180" x2="380" y2="320"/>
          <line class="edge e2" x1="380" y1="320" x2="640" y2="140"/>
          <line class="edge e3" x1="640" y1="140" x2="820" y2="420"/>
          <line class="edge e4" x1="820" y1="420" x2="1050" y2="260"/>
          <line class="edge e5" x1="1050" y1="260" x2="1280" y2="380"/>
          <line class="edge e6" x1="200"  y1="520" x2="480"  y2="600"/>
          <line class="edge e7" x1="480"  y1="600" x2="760"  y2="560"/>
          <line class="edge e8" x1="760"  y1="560" x2="980"  y2="680"/>
          <line class="edge e9" x1="120"  y1="180" x2="200"  y2="520"/>
          <line class="edge e10" x1="380" y1="320" x2="480"  y2="600"/>
          <line class="edge e11" x1="640" y1="140" x2="760"  y2="560"/>
          <line class="edge e12" x1="820" y1="420" x2="980"  y2="680"/>
          <line class="edge e13" x1="1050" y1="260" x2="1150" y2="500"/>
        </g>
        <!-- Scan line -->
        <rect class="scanline" x="0" y="0" width="1440" height="120" fill="url(#scanGrad)"/>
        <defs>
          <linearGradient id="scanGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stop-color="rgba(0,0,40,0)"/>
            <stop offset="50%"  stop-color="rgba(0,0,40,0.05)"/>
            <stop offset="100%" stop-color="rgba(0,0,40,0)"/>
          </linearGradient>
        </defs>
      </svg>
    </div>

    <div class="container-editorial" style="position:relative; z-index:1;">
      <p class="section-label reveal">Sane Design — Web Studio, Japan</p>

      <h1 class="hero-headline" style="margin-top:16px;">
        <span class="reveal" style="display:block; transition-delay:80ms;">Creating websites</span>
        <span class="reveal" style="display:block; transition-delay:160ms; font-style:italic;">that move people.</span>
      </h1>

      <div class="reveal" style="margin-top:40px; max-width:480px; transition-delay:240ms;">
        <p style="font-size:16px; color:var(--color-muted); line-height:1.9;">
          DTP・WEB 実績 300件以上。<br />
          最速3日納品・¥20,000〜のホームページ制作と<br />
          SEO対策のスタジオです。
        </p>
      </div>

      <div class="reveal" style="margin-top:40px; display:flex; flex-wrap:wrap; gap:16px; transition-delay:320ms;">
        <a href="/works/" class="btn-primary"><span>実績を見る →</span></a>
        <a href="/contact/" class="btn-ghost"><span>ご依頼・お問い合わせ</span></a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div style="position:absolute; bottom:40px; right:40px; display:flex; flex-direction:column; align-items:center; gap:8px; opacity:0.4;">
      <span style="font-size:9px; letter-spacing:0.2em; text-transform:uppercase; writing-mode:vertical-rl;">Scroll</span>
      <div style="width:1px; height:40px; background:var(--color-primary); animation: scrollLine 2s ease-in-out infinite;"></div>
    </div>
  </section>

  <!-- ── Numbers / Stats ── -->
  <section style="border-top:1px solid var(--color-border); border-bottom:1px solid var(--color-border); padding: 48px 0;">
    <div class="container-editorial">
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:2px;">
        <div class="reveal stat-item" style="padding:32px 40px; border-right:1px solid var(--color-border);">
          <p style="font-family:var(--font-serif); font-size:clamp(40px,5vw,64px); font-weight:300; line-height:1; letter-spacing:-0.02em;">300<span style="font-size:0.5em;">+</span></p>
          <p style="font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-muted); margin-top:8px;">Projects</p>
        </div>
        <div class="reveal stat-item" style="padding:32px 40px; border-right:1px solid var(--color-border); transition-delay:100ms;">
          <p style="font-family:var(--font-serif); font-size:clamp(40px,5vw,64px); font-weight:300; line-height:1; letter-spacing:-0.02em;">3<span style="font-size:0.4em;font-family:var(--font-sans);">日〜</span></p>
          <p style="font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-muted); margin-top:8px;">Delivery</p>
        </div>
        <div class="reveal stat-item" style="padding:32px 40px; transition-delay:200ms;">
          <p style="font-family:var(--font-serif); font-size:clamp(40px,5vw,64px); font-weight:300; line-height:1; letter-spacing:-0.02em;">¥20,000<span style="font-size:0.35em;font-family:var(--font-sans);">〜</span></p>
          <p style="font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-muted); margin-top:8px;">Starting Price</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Featured Works ── -->
  <section style="padding:100px 0;">
    <div class="container-editorial">
      <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:48px;">
        <div>
          <p class="section-label reveal">Featured Works</p>
          <h2 class="reveal" style="font-family:var(--font-serif); font-size:clamp(28px,4vw,52px); font-weight:300; transition-delay:80ms;">
            Selected Projects
          </h2>
        </div>
        <a href="/works/" class="hover-underline reveal" style="font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-muted); text-decoration:none; transition-delay:120ms;">
          View all works →
        </a>
      </div>

      <div class="works-grid-top">
        {
          works.map((work, i) => (
            <WorkCard
              title={work.data.title}
              client={work.data.client}
              year={work.data.year}
              thumbnail={work.data.thumbnail}
              href={`/works/${work.slug}/`}
              span="medium"
              index={i}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── Services ── -->
  <section style="padding:100px 0; background:var(--color-surface);">
    <div class="container-editorial">
      <p class="section-label reveal">Services</p>
      <h2 class="reveal" style="font-family:var(--font-serif); font-size:clamp(28px,4vw,52px); font-weight:300; margin-bottom:64px; transition-delay:80ms;">
        2 つのサービス
      </h2>

      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:2px;">
        <!-- Service 01 -->
        <div class="reveal service-card" style="padding:56px 48px; background:#fff; position:relative; overflow:hidden; transition-delay:100ms;">
          <div style="position:absolute; top:0; left:0; width:0; height:2px; background:var(--color-primary); transition: width 0.6s cubic-bezier(0.19,1,0.22,1);" class="top-line"></div>
          <p style="font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--color-muted); margin-bottom:24px;">01 — Web Design</p>
          <h3 style="font-family:var(--font-serif); font-size:clamp(24px,3vw,36px); font-weight:300; line-height:1.3; margin-bottom:24px;">
            ホームページを<br />最速 3 日で納品。
          </h3>
          <p style="font-size:14px; color:var(--color-muted); line-height:1.9; margin-bottom:32px;">
            画像とイメージをお渡しいただくだけで、トップ+4ページの完全オーダーメイドを ¥20,000〜 で制作します。コーポレートサイト・LP・士業・サロンなど幅広く対応。
          </p>
          <div style="display:flex; gap:24px; align-items:center;">
            <a href="/services/web-design/" class="hover-underline" style="font-size:12px; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none;">詳しく見る</a>
          </div>
        </div>

        <!-- Service 02 -->
        <div class="reveal service-card" style="padding:56px 48px; background:#fff; position:relative; overflow:hidden; transition-delay:200ms;">
          <div style="position:absolute; top:0; left:0; width:0; height:2px; background:var(--color-primary); transition: width 0.6s cubic-bezier(0.19,1,0.22,1);" class="top-line"></div>
          <p style="font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--color-muted); margin-bottom:24px;">02 — SEO</p>
          <h3 style="font-family:var(--font-serif); font-size:clamp(24px,3vw,36px); font-weight:300; line-height:1.3; margin-bottom:24px;">
            検索順位を<br />最短 3 日で変える。
          </h3>
          <p style="font-size:14px; color:var(--color-muted); line-height:1.9; margin-bottom:32px;">
            指定キーワードに基づく厳選 60 記事追加と内部 SEO 対策を ¥10,000〜 で提供。Google 検索での集客を強化し、持続的なアクセスを生み出します。
          </p>
          <div style="display:flex; gap:24px; align-items:center;">
            <a href="/services/seo/" class="hover-underline" style="font-size:12px; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none;">詳しく見る</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Process ── -->
  <section style="padding:100px 0;">
    <div class="container-editorial">
      <p class="section-label reveal">How it works</p>
      <h2 class="reveal" style="font-family:var(--font-serif); font-size:clamp(28px,4vw,52px); font-weight:300; margin-bottom:64px; transition-delay:80ms;">
        制作の流れ
      </h2>
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:2px;">
        {[
          { step:'01', title:'ご依頼', desc:'ご予算・ページ数・イメージをお伝えください。ご不明点があってもご相談から対応します。' },
          { step:'02', title:'素材入稿', desc:'画像・テキスト・ロゴなどの素材をお送りください。この時点で制作を開始します。' },
          { step:'03', title:'デザイン制作', desc:'最速3日でデザイン・コーディングを完成させ、確認用URLをお送りします。' },
          { step:'04', title:'納品・公開', desc:'ご確認後、1〜2回の修正対応のうえ最終納品。ドメイン・サーバー設定もサポートします。' },
        ].map((item, i) => (
          <div class="reveal" style={`padding:40px 32px; border-top:1px solid var(--color-border); transition-delay:${i * 80}ms;`}>
            <p style="font-family:var(--font-serif); font-size:32px; font-weight:300; color:var(--color-border); margin-bottom:16px;">{item.step}</p>
            <h3 style="font-size:16px; font-weight:500; margin-bottom:12px; font-family:var(--font-serif);">{item.title}</h3>
            <p style="font-size:13px; color:var(--color-muted); line-height:1.9;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Journal ── -->
  {blogs.length > 0 && (
    <section style="padding:100px 0; border-top:1px solid var(--color-border);">
      <div class="container-editorial">
        <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:48px;">
          <div>
            <p class="section-label reveal">Journal</p>
            <h2 class="reveal" style="font-family:var(--font-serif); font-size:clamp(28px,4vw,52px); font-weight:300; transition-delay:80ms;">
              Writings
            </h2>
          </div>
          <a href="/blog/" class="hover-underline reveal" style="font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-muted); text-decoration:none; transition-delay:120ms;">
            View all →
          </a>
        </div>
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:2px;">
          {
            blogs.map((post, i) => (
              <a href={`/blog/${post.slug}/`} class="reveal" style={`display:block; padding:32px; border:1px solid var(--color-border); text-decoration:none; transition-delay:${i * 80}ms; transition: background 0.3s ease;`}
                onmouseover="this.style.background='var(--color-surface)'"
                onmouseout="this.style.background=''"
              >
                <time style="font-size:10px; letter-spacing:0.1em; color:var(--color-muted);">
                  {post.data.pubDate.toISOString().slice(0, 10)}
                </time>
                <h3 style="font-family:var(--font-serif); font-size:18px; font-weight:400; margin-top:12px; line-height:1.5;">{post.data.title}</h3>
                <p style="font-size:12px; color:var(--color-muted); margin-top:8px; line-height:1.8; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">{post.data.description}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  )}

  <CTABanner />
</BaseLayout>

<style>
  /* ── Hero background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-svg {
    width: 100%;
    height: 100%;
  }

  /* ノードの浮遊アニメーション */
  .node { animation: float linear infinite; }
  .n1  { animation-duration: 18s; animation-delay: 0s; }
  .n2  { animation-duration: 22s; animation-delay: -4s; }
  .n3  { animation-duration: 16s; animation-delay: -8s; }
  .n4  { animation-duration: 24s; animation-delay: -2s; }
  .n5  { animation-duration: 20s; animation-delay: -6s; }
  .n6  { animation-duration: 26s; animation-delay: -10s; }
  .n7  { animation-duration: 19s; animation-delay: -3s; }
  .n8  { animation-duration: 23s; animation-delay: -7s; }
  .n9  { animation-duration: 17s; animation-delay: -11s; }
  .n10 { animation-duration: 25s; animation-delay: -5s; }
  .n11 { animation-duration: 21s; animation-delay: -9s; }
  .n12 { animation-duration: 28s; animation-delay: -1s; }

  @keyframes float {
    0%   { transform: translate(0px, 0px); }
    25%  { transform: translate(12px, -16px); }
    50%  { transform: translate(-8px, -28px); }
    75%  { transform: translate(16px, -12px); }
    100% { transform: translate(0px, 0px); }
  }

  /* エッジのフェードアニメーション */
  .edge { animation: edgeFade linear infinite; }
  .e1  { animation-duration: 14s; animation-delay: 0s; }
  .e2  { animation-duration: 18s; animation-delay: -3s; }
  .e3  { animation-duration: 12s; animation-delay: -6s; }
  .e4  { animation-duration: 20s; animation-delay: -2s; }
  .e5  { animation-duration: 16s; animation-delay: -8s; }
  .e6  { animation-duration: 22s; animation-delay: -4s; }
  .e7  { animation-duration: 15s; animation-delay: -7s; }
  .e8  { animation-duration: 19s; animation-delay: -1s; }
  .e9  { animation-duration: 24s; animation-delay: -5s; }
  .e10 { animation-duration: 13s; animation-delay: -9s; }
  .e11 { animation-duration: 17s; animation-delay: -11s; }
  .e12 { animation-duration: 21s; animation-delay: -3s; }
  .e13 { animation-duration: 11s; animation-delay: -7s; }

  @keyframes edgeFade {
    0%   { opacity: 0.15; }
    40%  { opacity: 0.55; }
    70%  { opacity: 0.20; }
    100% { opacity: 0.15; }
  }

  /* スキャンライン */
  .scanline {
    animation: scanDown 12s linear infinite;
  }
  @keyframes scanDown {
    0%   { transform: translateY(-120px); }
    100% { transform: translateY(920px); }
  }

  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    50.1% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }
  .service-card:hover .top-line {
    width: 100% !important;
  }
  .works-grid-top {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  @media (max-width: 768px) {
    .works-grid-top {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .editorial-grid { gap: 2px; }
    section > div > div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
    section > div > div[style*="grid-template-columns:repeat(4"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    section > div > div[style*="grid-template-columns:repeat(3"] {
      grid-template-columns: 1fr !important;
    }
    section > div > div[style*="grid-template-columns:repeat(3,1fr)"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>


  // Scroll Reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-left, .reveal-scale').forEach((el) => {
    observer.observe(el);
  });
</script>
