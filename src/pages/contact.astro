---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact｜ご依頼・お問い合わせ | Sane Design"
  description="Sane Designへのご依頼・お問い合わせ。ホームページ制作は¥20,000〜、SEO対策は¥10,000〜。フォームからお気軽にご相談ください。"
>
  <!-- Hero -->
  <section style="padding:80px 0 60px;">
    <div class="container-editorial">
      <p class="section-label reveal">Contact</p>
      <h1 class="reveal" style="font-family:var(--font-serif); font-size:clamp(40px,7vw,100px); font-weight:300; line-height:1.05; letter-spacing:-0.02em; transition-delay:80ms;">
        Let's make<br />
        <span style="font-style:italic;">something.</span>
      </h1>
      <p class="reveal" style="margin-top:24px; max-width:480px; font-size:15px; color:var(--color-muted); line-height:1.9; transition-delay:160ms;">
        ご依頼・ご相談はお気軽にどうぞ。<br />
        通常24時間以内にご返信します。
      </p>
    </div>
  </section>

  <!-- Service Links -->
  <section style="padding:0 0 80px;">
    <div class="container-editorial">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:2px;" class="contact-grid">
        <div
          class="reveal contact-card"
          style="display:block; padding:56px 48px; border:1px solid var(--color-border); position:relative; overflow:hidden;"
        >
          <div style="position:absolute; top:0; left:0; right:0; height:2px; background:var(--color-primary); transform:scaleX(0); transform-origin:left; transition: transform 0.5s cubic-bezier(0.19,1,0.22,1);" class="card-line"></div>
          <p style="font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--color-muted); margin-bottom:24px;">01 — Web Design</p>
          <h2 style="font-family:var(--font-serif); font-size:clamp(22px,2.5vw,32px); font-weight:300; line-height:1.3; margin-bottom:20px;">
            ホームページ制作を<br />依頼する
          </h2>
          <p style="font-size:13px; color:var(--color-muted); line-height:1.9; margin-bottom:32px;">
            最速3日・¥20,000〜。画像とイメージをお渡しいただくだけで、完全オーダーメイドで制作します。
          </p>
          <span style="font-size:12px; letter-spacing:0.1em; text-transform:uppercase; border-bottom:1px solid currentColor; padding-bottom:2px;">詳細を見る →</span>
        </div>

        <div
          class="reveal contact-card"
          style="display:block; padding:56px 48px; border:1px solid var(--color-border); position:relative; overflow:hidden; transition-delay:100ms;"
        >
          <div style="position:absolute; top:0; left:0; right:0; height:2px; background:var(--color-primary); transform:scaleX(0); transform-origin:left; transition: transform 0.5s cubic-bezier(0.19,1,0.22,1);" class="card-line"></div>
          <p style="font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--color-muted); margin-bottom:24px;">02 — SEO</p>
          <h2 style="font-family:var(--font-serif); font-size:clamp(22px,2.5vw,32px); font-weight:300; line-height:1.3; margin-bottom:20px;">
            SEO 対策を<br />依頼する
          </h2>
          <p style="font-size:13px; color:var(--color-muted); line-height:1.9; margin-bottom:32px;">
            最短3日・¥10,000〜。指定KWの記事60本追加と内部SEO対策を実施します。
          </p>
          <span style="font-size:12px; letter-spacing:0.1em; text-transform:uppercase; border-bottom:1px solid currentColor; padding-bottom:2px;">詳細を見る →</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Email Contact Form -->
  <section style="padding:80px 0; border-top:1px solid var(--color-border);">
    <div class="container-editorial">
      <div style="max-width:640px;">
        <p class="section-label reveal">Direct Message</p>
        <h2 class="reveal" style="font-family:var(--font-serif); font-size:clamp(24px,3vw,40px); font-weight:300; margin-bottom:12px; transition-delay:80ms;">
          メールでお問い合わせ
        </h2>
        <p class="reveal" style="font-size:13px; color:var(--color-muted); margin-bottom:40px; transition-delay:120ms;">
          ご質問・お見積りのご相談など、お気軽にご連絡ください。通常24時間以内にご返信します。
        </p>

        <form
          class="reveal"
          id="contact-form"
          style="display:flex; flex-direction:column; gap:24px; transition-delay:160ms;"
          action="https://formspree.io/f/xpwpojpq"
          method="POST"
        >
          <input type="hidden" name="_subject" value="【Sane Design】お問い合わせ" />
          <input type="hidden" name="_to" value="saneatsu.designs@gmail.com" />
          <input type="text" name="_gotcha" style="display:none;" />

          <div class="form-group">
            <label style="display:block; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:8px; color:var(--color-muted);">
              お名前 <span style="color:#c00;">*</span>
            </label>
            <input
              type="text"
              name="name"
              required
              placeholder="山田 太郎"
              style="width:100%; padding:14px 16px; border:1px solid var(--color-border); background:#fff; font-size:14px; font-family:var(--font-sans); outline:none; transition: border-color 0.3s ease;"
              class="form-input"
            />
          </div>

          <div class="form-group">
            <label style="display:block; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:8px; color:var(--color-muted);">
              メールアドレス <span style="color:#c00;">*</span>
            </label>
            <input
              type="email"
              name="email"
              required
              placeholder="your@email.com"
              style="width:100%; padding:14px 16px; border:1px solid var(--color-border); background:#fff; font-size:14px; font-family:var(--font-sans); outline:none; transition: border-color 0.3s ease;"
              class="form-input"
            />
          </div>

          <div class="form-group">
            <label style="display:block; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:8px; color:var(--color-muted);">
              ご依頼・ご相談の種類
            </label>
            <select
              name="service"
              style="width:100%; padding:14px 16px; border:1px solid var(--color-border); background:#fff; font-size:14px; font-family:var(--font-sans); outline:none; transition: border-color 0.3s ease; appearance:none; cursor:pointer;"
              class="form-input"
            >
              <option value="">選択してください</option>
              <option value="ホームページ制作">ホームページ制作</option>
              <option value="LP制作">LP制作</option>
              <option value="SEO対策">SEO対策</option>
              <option value="その他">その他</option>
            </select>
          </div>

          <div class="form-group">
            <label style="display:block; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:8px; color:var(--color-muted);">
              メッセージ <span style="color:#c00;">*</span>
            </label>
            <textarea
              name="message"
              required
              rows="6"
              placeholder="ご依頼内容・ご予算・ご希望納期などをご記入ください"
              style="width:100%; padding:14px 16px; border:1px solid var(--color-border); background:#fff; font-size:14px; font-family:var(--font-sans); outline:none; resize:vertical; transition: border-color 0.3s ease; line-height:1.8;"
              class="form-input"
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn-primary"
            style="align-self:flex-start;"
            id="submit-btn"
          >
            <span>送信する →</span>
          </button>

          <div id="form-message" style="display:none; padding:16px; font-size:13px;"></div>
        </form>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding:80px 0; border-top:1px solid var(--color-border);">
    <div class="container-editorial">
      <div style="max-width:720px;">
        <p class="section-label reveal">FAQ</p>
        <h2 class="reveal" style="font-family:var(--font-serif); font-size:clamp(24px,3vw,40px); font-weight:300; margin-bottom:48px; transition-delay:80ms;">
          よくあるご質問
        </h2>
        <dl style="display:flex; flex-direction:column; gap:0;">
          {[
            { q: 'ご依頼の流れを教えてください。', a: 'ご連絡いただき内容を確認後、画像・テキスト等の素材をご入稿いただきます。その後3〜5営業日でデザインを仕上げ、確認URLをお送りします。' },
            { q: 'ページ数や追加修正の対応は？', a: 'トップ+4ページが基本セットです。追加ページや修正は都度ご相談ください。1〜2回の微修正は無料で対応します。' },
            { q: 'ドメイン・サーバーは自分で用意が必要ですか？', a: 'ご自身でご用意いただく形が基本ですが、初期設定のサポートもお受けしています。' },
            { q: 'ご予算が少ない場合でも相談できますか？', a: 'もちろんです。まずはお気軽にご相談ください。内容に合わせた最適なプランをご提案します。' },
          ].map((item, i) => (
            <div class="reveal faq-item" style={`border-top:1px solid var(--color-border); transition-delay:${i * 60}ms;`}>
              <button
                class="faq-toggle"
                style="width:100%; padding:24px 0; display:flex; justify-content:space-between; align-items:center; text-align:left; background:none; border:none; cursor:pointer; gap:16px;"
              >
                <span style="font-family:var(--font-serif); font-size:16px; font-weight:400; line-height:1.5;">Q. {item.q}</span>
                <span class="faq-icon" style="font-size:18px; flex-shrink:0; transition: transform 0.4s ease; color:var(--color-muted);">+</span>
              </button>
              <div class="faq-body" style="overflow:hidden; max-height:0; transition: max-height 0.5s cubic-bezier(0.19,1,0.22,1);">
                <p style="padding-bottom:24px; font-size:14px; color:var(--color-muted); line-height:1.9;">{item.a}</p>
              </div>
            </div>
          ))}
          <div style="border-top:1px solid var(--color-border);"></div>
        </dl>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .form-input:focus {
    border-color: var(--color-primary) !important;
  }
  .contact-card:hover .card-line {
    transform: scaleX(1) !important;
  }
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  // Scroll Reveal
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // FAQ accordion
  document.querySelectorAll('.faq-item').forEach(item => {
    const toggle = item.querySelector('.faq-toggle');
    const body = item.querySelector('.faq-body') as HTMLElement | null;
    const icon = item.querySelector('.faq-icon');
    toggle?.addEventListener('click', () => {
      const isOpen = body?.style.maxHeight !== '0px' && body?.style.maxHeight !== '';
      if (body) body.style.maxHeight = isOpen ? '0' : body.scrollHeight + 'px';
      if (icon) (icon as HTMLElement).style.transform = isOpen ? '' : 'rotate(45deg)';
    });
  });

  // Form submission feedback
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const msg = document.getElementById('form-message');
  const btn = document.getElementById('submit-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !msg) return;
    btn.setAttribute('disabled', 'true');
    (btn.querySelector('span') as HTMLElement).textContent = '送信中...';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      });

      if (res.ok) {
        msg.style.display = 'block';
        msg.style.background = '#f0f9f0';
        msg.style.border = '1px solid #b0d8b0';
        msg.style.color = '#2a6a2a';
        msg.textContent = 'お問い合わせありがとうございます。24時間以内にご返信いたします。';
        form.reset();
      } else {
        throw new Error('送信エラー');
      }
    } catch {
      msg.style.display = 'block';
      msg.style.background = '#fff0f0';
      msg.style.border = '1px solid #d8b0b0';
      msg.style.color = '#6a2a2a';
      msg.textContent = '送信に失敗しました。直接 saneatsu.designs@gmail.com へご連絡ください。';
    } finally {
      btn.removeAttribute('disabled');
      (btn.querySelector('span') as HTMLElement).textContent = '送信する →';
    }
  });
</script>
