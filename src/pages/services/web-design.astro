---
import BaseLayout from '../../layouts/BaseLayout.astro';
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<BaseLayout
  title="Web Design｜ホームページ制作 | Sane Design"
  description="最速3日納品・20,000円〜。画像とイメージをお渡しいただくだけで、個人事業主・中小企業向けのホームページを完全オーダーメイドで制作します。実績300件以上。"
>
  <section class="container-editorial pt-16 md:pt-24 pb-16">
    <p class="section-label">Services / 01</p>
    <h1 class="font-serif text-4xl md:text-7xl leading-tight mb-6">
      Web Design.
    </h1>
    <p class="max-w-2xl text-base md:text-xl leading-relaxed">
      最速3日でホームページを納品します。<br />
      画像とイメージをお渡しいただくだけで、完全オーダーメイドで制作。
    </p>
  </section>

  <section class="container-editorial pb-16">
    <div class="border-t border-primary pt-8 grid md:grid-cols-4 gap-8 text-sm">
      <div>
        <p class="text-xs uppercase tracking-widest text-muted mb-2">価格</p>
        <p class="font-serif text-2xl">¥20,000〜</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-muted mb-2">納期</p>
        <p class="font-serif text-2xl">3〜4営業日</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-muted mb-2">ページ数</p>
        <p class="font-serif text-2xl">TOP + 4P</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-muted mb-2">納品形態</p>
        <p class="font-serif text-2xl">HTML / サーバー</p>
      </div>
    </div>
  </section>

  <section class="container-editorial pb-16">
    <h2 class="font-serif text-3xl md:text-4xl mb-8">こんな方におすすめ</h2>
    <ul class="space-y-4 text-base md:text-lg max-w-2xl">
      <li class="flex gap-4">
        <span class="text-accent">✓</span>個人事業主・店舗で、急ぎHPが必要
      </li>
      <li class="flex gap-4">
        <span class="text-accent">✓</span>デザインのイメージが固まっていない
      </li>
      <li class="flex gap-4">
        <span class="text-accent">✓</span>WordPressではなく軽くて速いサイトが欲しい
      </li>
      <li class="flex gap-4">
        <span class="text-accent">✓</span>予算を抑えたい
      </li>
    </ul>
  </section>

  <section class="container-editorial pb-16">
    <h2 class="font-serif text-3xl md:text-4xl mb-8">制作の流れ</h2>
    <ol class="space-y-6 max-w-2xl">
      {
        [
          { num: '01', title: 'ご依頼', desc: 'フォームからご連絡ください。' },
          { num: '02', title: 'ヒアリング', desc: '画像・文章・ご要望を共有していただきます。' },
          { num: '03', title: '初稿提出', desc: '1〜2営業日で初稿をご確認いただきます。' },
          { num: '04', title: '修正・調整', desc: 'フィードバックを反映します。' },
          { num: '05', title: '納品', desc: '合計3〜4営業日で納品完了。' },
        ].map((step) => (
          <li class="flex gap-6 border-t border-border pt-4">
            <span class="font-serif text-2xl text-muted">{step.num}</span>
            <div>
              <h3 class="font-semibold mb-1">{step.title}</h3>
              <p class="text-sm text-muted">{step.desc}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Coconala サービス情報 -->
  <section class="container-editorial pb-16">
    <h2 class="font-serif text-3xl md:text-4xl mb-8">サービス詳細</h2>
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl">
      <div class="border-t border-primary pt-4">
        <h3 class="font-serif text-xl mb-3">含まれるもの</h3>
        <ul class="space-y-2 text-sm text-muted leading-relaxed">
          <li>✓ デザイン（レスポンシブ・スマホ対応）</li>
          <li>✓ SEO対応</li>
          <li>✓ 画像・素材の用意</li>
          <li>✓ 文章作成</li>
          <li>✓ SNS機能 / ギャラリー / お問い合わせフォーム</li>
          <li>✓ 地図 / 動画挿入 / FAQ / イベント</li>
          <li>✓ 無料修正：無制限</li>
        </ul>
      </div>
      <div class="border-t border-primary pt-4">
        <h3 class="font-serif text-xl mb-3">オプション</h3>
        <ul class="space-y-2 text-sm text-muted leading-relaxed">
          <li>＋ ¥3,000 — サーバーへの直接アップロード・公開対応</li>
          <li>＋ ¥10,000 — デザイン提出後の大幅変更</li>
          <li>＋ ¥40,000 — ECサイト構築（Stripe / Square 決済連携含）</li>
          <li>＋ ¥1,000 — 軽微な修正（画像入替・役員追加など）</li>
          <li>＋ ¥5,000 — 大規模修正（文字1,000字以上・画像20枚以上）</li>
        </ul>
      </div>
    </div>
    <div class="mt-8 max-w-4xl border-t border-primary pt-6">
      <p class="text-sm text-muted leading-relaxed">
        ご不明点はお気軽にご相談ください。サーバー・ドメインの選び方、ページ追加、ECサイト構築なども対応しております。<br />
        初回返答：<strong>2時間以内（実績）</strong>／ 納期：<strong>約5日（実績）</strong>
      </p>
    </div>
  </section>


  <!-- Web制作実績ギャラリー -->
  <section class="container-editorial pb-16" id="web-works">
    <div class="wd-section-head">
      <h2 class="font-serif text-3xl md:text-4xl">制作実績</h2>
      <a href="/works/" class="wd-view-all">すべて見る →</a>
    </div>
    <div class="wd-grid" id="wd-grid">
      <div class="wd-loading">
        <span class="wd-dot"></span><span class="wd-dot"></span><span class="wd-dot"></span>
      </div>
    </div>
  </section>

  <section class="bg-accent text-white py-20 md:py-32 mt-12">
    <div class="container-editorial text-center">
      <h2 class="font-serif text-3xl md:text-5xl mb-6 leading-tight">
        ¥20,000 / 3日納品
      </h2>
      <p class="mb-8 opacity-90">
        フォームからお気軽にご相談ください
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:16px; justify-content:center;">
        <a
          href="/payment/"
          class="inline-block bg-white text-black no-underline px-12 py-5 font-semibold hover:opacity-85 transition-opacity"
        >
          今すぐ注文する →
        </a>
        <a
          href="/contact/#contact-form"
          class="inline-block bg-transparent text-white no-underline px-12 py-5 font-semibold border border-white hover:opacity-85 transition-opacity"
        >
          まずは相談する →
        </a>
      </div>
    </div>
  </section>

<style is:global>
  /* ── Web Design Works Gallery ── */
  .wd-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 32px;
    border-top: 1px solid var(--color-border);
    padding-top: 24px;
  }
  .wd-view-all {
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .wd-view-all:hover { color: var(--color-primary); }

  .wd-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 24px;
  }
  .wd-loading {
    grid-column: 1/-1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 60px 0;
  }
  .wd-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-muted);
    animation: wdPulse 1.2s ease-in-out infinite;
  }
  .wd-dot:nth-child(2) { animation-delay: 0.2s; }
  .wd-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes wdPulse {
    0%,80%,100% { opacity:0.2; transform:scale(0.8); }
    40% { opacity:1; transform:scale(1); }
  }

  .wd-card {
    display: block;
    text-decoration: none;
    animation: wdFade 0.7s cubic-bezier(0.19,1,0.22,1) both;
  }
  @keyframes wdFade {
    from { opacity:0; transform:translateY(24px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .wd-thumb {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    width: 100%;
    padding-top: 66.67%;
    border-radius: 4px;
  }
  .wd-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.9s cubic-bezier(0.19,1,0.22,1);
  }
  .wd-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 55%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .wd-hover {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 18px 18px 16px;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 8px;
    opacity: 0; transform: translateY(8px);
    transition: all 0.35s cubic-bezier(0.19,1,0.22,1);
  }
  .wd-hover-name { font-size: 13px; color: #fff; font-family: var(--font-serif); }
  .wd-hover-badge {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.3);
    padding: 4px 11px; border-radius: 100px;
    font-size: 10px; color: #fff;
    letter-spacing: 0.1em; text-transform: uppercase;
    white-space: nowrap; flex-shrink: 0;
  }
  .wd-card:hover .wd-img { transform: scale(1.05); }
  .wd-card:hover .wd-overlay { opacity: 1; }
  .wd-card:hover .wd-hover { opacity: 1; transform: translateY(0); }

  .wd-meta {
    margin-top: 14px;
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 10px;
  }
  .wd-client {
    font-family: var(--font-serif);
    font-size: 14px; font-weight: 400; line-height: 1.4;
    color: var(--color-primary);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .wd-title-text {
    font-size: 11px; color: var(--color-muted);
    letter-spacing: 0.04em; margin-top: 3px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .wd-year {
    font-size: 11px; color: var(--color-muted);
    white-space: nowrap; padding-top: 2px; flex-shrink: 0;
  }

  @media (max-width: 900px) { .wd-grid { grid-template-columns: repeat(2,1fr); gap:24px 16px; } }
  @media (max-width: 560px) { .wd-grid { grid-template-columns: 1fr; gap:32px; } }
</style>

<script define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
(async () => {
  try {
    const res = await fetch(
      `${SUPABASE_URL}/rest/v1/portfolio_works?draft=eq.false&order=display_order.asc&select=*`,
      { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${SUPABASE_KEY}` } }
    );
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const works = await res.json();
    const grid = document.getElementById('wd-grid');
    if (!grid) return;
    grid.innerHTML = '';

    // 最新12件のみ表示（display_order昇順=最新から）
    works.slice(0, 12).forEach((w, i) => {
      const isExt = !!w.external_url;
      const href = w.external_url || `/works/`;
      const el = document.createElement('div');
      el.innerHTML = `
        <a href="${href}" class="wd-card"
          ${isExt ? 'target="_blank" rel="noopener noreferrer"' : ''}
          style="animation-delay:${i*55}ms">
          <div class="wd-thumb">
            <img src="${w.thumbnail_url}" alt="${w.client}" loading="lazy" class="wd-img"/>
            <div class="wd-overlay"></div>
            <div class="wd-hover">
              <span class="wd-hover-name">${w.client}</span>
              <span class="wd-hover-badge">${isExt ? 'Visit ↗' : 'View →'}</span>
            </div>
          </div>
          <div class="wd-meta">
            <div style="min-width:0;flex:1">
              <p class="wd-client">${w.client}</p>
              <p class="wd-title-text">${w.title}</p>
            </div>
            <span class="wd-year">${w.year}</span>
          </div>
        </a>`;
      grid.appendChild(el.firstElementChild);
    });
  } catch(e) {
    const g = document.getElementById('wd-grid');
    if (g) g.innerHTML = '';
  }
})();
</script>

</BaseLayout>
