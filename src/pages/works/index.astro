---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<BaseLayout
  title="Works｜実績一覧 | Sane Design"
  description="Sane Designのホームページ制作実績一覧。コーポレートサイト、LP、サロン予約サイト、士業サイトなど300件以上の制作実績から代表作をご紹介します。"
>
  <!-- Hero -->
  <section class="works-hero">
    <div class="container-editorial">
      <p class="section-label reveal">Works</p>
      <h1 class="reveal works-title">
        Selected<br />
        <span style="font-style:italic;">Projects.</span>
      </h1>
      <p class="reveal works-desc">
        DTP・WEB 合わせて 300 件以上の実績より、<br />代表的なプロジェクトをご紹介します。
      </p>
    </div>
  </section>

  <!-- Filter -->
  <div class="container-editorial reveal filter-wrap">
    <div class="filter-row" id="filter-row">
      <button class="filter-btn active" data-filter="all">All</button>
    </div>
  </div>

  <!-- Works grid -->
  <section class="container-editorial works-grid-section">
    <div class="works-grid" id="works-grid">
      <div class="loading-state">読み込み中...</div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>

<style>
  .works-hero { padding: 80px 0 60px; }
  .works-title {
    font-family: var(--font-serif);
    font-size: clamp(40px, 7vw, 100px);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-top: 16px;
  }
  .works-desc {
    margin-top: 24px;
    max-width: 480px;
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.9;
  }
  .filter-wrap { padding-bottom: 48px; }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    border-top: 1px solid var(--color-border);
    padding-top: 24px;
  }
  .filter-btn {
    padding: 6px 16px;
    border: 1px solid var(--color-border);
    background: transparent;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: var(--font-sans);
  }
  .filter-btn:hover, .filter-btn.active {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: #fff;
  }
  .works-grid-section { padding-bottom: 120px; }
  .works-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 24px;
  }
  .work-item { display: block; }
  .work-item.hidden { display: none; }
  .loading-state {
    grid-column: 1/-1;
    text-align: center;
    padding: 80px;
    color: var(--color-muted);
    font-size: 14px;
  }

  /* WorkCard styles */
  .work-card {
    display: block;
    text-decoration: none;
    animation: workFadeIn 0.7s cubic-bezier(0.19, 1, 0.22, 1) both;
  }
  @keyframes workFadeIn {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .work-thumb {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    width: 100%;
    padding-top: 66.67%; /* 3:2 固定アスペクト比 */
  }
  .work-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .work-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    transition: background 0.4s ease;
  }
  .view-label {
    position: absolute;
    bottom: 16px;
    right: 16px;
    background: #fff;
    padding: 6px 14px;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .work-card:hover .work-img { transform: scale(1.06); }
  .work-card:hover .work-overlay { background: rgba(0,0,0,0.08); }
  .work-card:hover .view-label { opacity: 1; transform: translateY(0); }
  .work-meta {
    margin-top: 12px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }
  .work-client {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.4;
    margin-bottom: 4px;
    color: var(--color-primary);
  }
  .work-title-text {
    font-size: 11px;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }
  .work-year {
    font-size: 11px;
    color: var(--color-muted);
    white-space: nowrap;
    padding-top: 2px;
  }

  @media (max-width: 900px) {
    .works-grid { grid-template-columns: repeat(2, 1fr); gap: 24px 16px; }
  }
  @media (max-width: 560px) {
    .works-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>

<script define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
  async function loadWorks(filter = 'all') {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/portfolio_works?draft=eq.false&order=display_order.asc&select=*`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` } }
      );
      const works = await res.json();

      // フィルターボタン生成
      const allTags = [...new Set(works.flatMap(w => w.tags || []))].sort();
      const filterRow = document.getElementById('filter-row');
      filterRow.innerHTML = '<button class="filter-btn active" data-filter="all">All</button>';
      allTags.forEach(tag => {
        const btn = document.createElement('button');
        btn.className = 'filter-btn';
        btn.dataset.filter = tag;
        btn.textContent = tag;
        filterRow.appendChild(btn);
      });

      // フィルターイベント
      filterRow.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          filterRow.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const f = btn.dataset.filter;
          document.querySelectorAll('.work-item').forEach(item => {
            if (f === 'all') {
              item.classList.remove('hidden');
            } else {
              const tags = item.dataset.tags || '';
              item.classList.toggle('hidden', !tags.includes(f));
            }
          });
        });
      });

      // グリッド描画
      const grid = document.getElementById('works-grid');
      grid.innerHTML = '';

      works.forEach((work, i) => {
        const isExternal = !!work.external_url;
        const href = work.external_url || '#';
        const tags = (work.tags || []).join(',');

        const item = document.createElement('div');
        item.className = 'work-item';
        item.dataset.tags = tags;

        item.innerHTML = `
          <a href="${href}" class="work-card"
            ${isExternal ? 'target="_blank" rel="noopener noreferrer"' : ''}
            style="animation-delay:${i * 60}ms"
          >
            <div class="work-thumb">
              <img src="${work.thumbnail_url}" alt="${work.client}" loading="lazy" class="work-img" />
              <div class="work-overlay"></div>
              <div class="view-label">${isExternal ? 'Visit →' : 'View →'}</div>
            </div>
            <div class="work-meta">
              <div>
                <p class="work-client">${work.client}</p>
                <p class="work-title-text">${work.title}</p>
              </div>
              <span class="work-year">${work.year}</span>
            </div>
          </a>`;
        grid.appendChild(item);
      });

      // Scroll reveal
      const observer = new IntersectionObserver(
        entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.05 }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    } catch(e) {
      document.getElementById('works-grid').innerHTML = '<div class="loading-state">読み込みに失敗しました</div>';
    }
  }

  loadWorks();
</script>
