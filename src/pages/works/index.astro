---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkCard from '../../components/WorkCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getCollection } from 'astro:content';

const works = (await getCollection('works', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const categories = [...new Set(works.flatMap(w => w.data.tags || []))];
---

<BaseLayout
  title="Works｜実績一覧 | Sane Design"
  description="Sane Designのホームページ制作実績一覧。コーポレートサイト、LP、サロン予約サイト、士業サイトなど300件以上の制作実績から代表作をご紹介します。"
>
  <!-- Hero -->
  <section class="works-hero">
    <div class="container-editorial">
      <p class="section-label reveal">Works</p>
      <h1 class="reveal works-title">
        Selected<br />
        <span style="font-style:italic;">Projects.</span>
      </h1>
      <p class="reveal works-desc">
        DTP・WEB 合わせて 300 件以上の実績より、<br />代表的なプロジェクトをご紹介します。
      </p>
    </div>
  </section>

  <!-- Filter -->
  <div class="container-editorial reveal filter-wrap">
    <div class="filter-row">
      <button class="filter-btn active" data-filter="all">All</button>
      {categories.map(cat => (
        <button class="filter-btn" data-filter={cat}>{cat}</button>
      ))}
    </div>
  </div>

  <!-- Works grid -->
  <section class="container-editorial works-grid-section" id="works-grid">
    <div class="works-grid">
      {works.map((work, i) => (
        <div
          class="work-item"
          data-tags={(work.data.tags || []).join(',')}
          style={`grid-column: span ${i % 5 === 0 ? 6 : 4};`}
        >
          <WorkCard
            title={work.data.title}
            client={work.data.client}
            year={work.data.year}
            thumbnail={work.data.thumbnail}
            href={`/works/${work.slug}/`}
            span={i % 5 === 0 ? 'large' : 'medium'}
            index={i}
          />
        </div>
      ))}
    </div>
  </section>

  <CTABanner />
</BaseLayout>

<style>
  .works-hero {
    padding: 80px 0 60px;
  }
  .works-title {
    font-family: var(--font-serif);
    font-size: clamp(40px, 7vw, 100px);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-top: 16px;
  }
  .works-desc {
    margin-top: 24px;
    max-width: 480px;
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.9;
  }
  .filter-wrap {
    padding-bottom: 48px;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    border-top: 1px solid var(--color-border);
    padding-top: 24px;
  }
  .filter-btn {
    padding: 6px 16px;
    border: 1px solid var(--color-border);
    background: transparent;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: var(--font-sans);
  }
  .filter-btn:hover,
  .filter-btn.active {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: #fff;
  }

  /* Works grid */
  .works-grid-section {
    padding-bottom: 120px;
  }
  .works-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 32px 24px;
  }
  .work-item {
    /* デフォルトは span 4 (inline styleで上書き) */
  }
  .work-item.hidden {
    display: none;
  }

  @media (max-width: 900px) {
    .works-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 16px;
    }
    .work-item {
      grid-column: span 1 !important;
    }
  }
  @media (max-width: 560px) {
    .works-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .work-item {
      grid-column: span 1 !important;
    }
  }
</style>

<script>
  // Scroll Reveal
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.05, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Filter
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('.work-item').forEach(item => {
        if (filter === 'all') {
          item.classList.remove('hidden');
        } else {
          const tags = item.getAttribute('data-tags') || '';
          item.classList.toggle('hidden', !tags.includes(filter));
        }
      });
    });
  });
</script>
