---
import { SITE_NAME, NAV_LINKS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-24">
  <div class="container-editorial py-12">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <a href="/" class="text-lg font-semibold no-underline">{SITE_NAME}</a>
      <nav class="flex flex-wrap gap-6 text-sm" aria-label="Footer">
        {
          NAV_LINKS.map((link) => (
            <a href={link.href} class="no-underline">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>
    <p class="mt-8 text-xs text-muted">
      © {year} {SITE_NAME}. All rights reserved.
    </p>
  </div>
</footer>
